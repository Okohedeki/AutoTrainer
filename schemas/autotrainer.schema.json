{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autotrainer.dev/schemas/autotrainer.schema.json",
  "title": "AutoTrainer experiment configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project", "model", "sources", "qlora", "sft", "grpo", "environment", "evaluation", "package"],
  "properties": {
    "schema_version": { "const": 1 },
    "project": { "$ref": "#/$defs/project" },
    "model": { "$ref": "#/$defs/model" },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" }
    },
    "qlora": { "$ref": "#/$defs/qlora" },
    "sft": { "$ref": "#/$defs/sft" },
    "grpo": { "$ref": "#/$defs/grpo" },
    "environment": { "$ref": "#/$defs/environment" },
    "evaluation": { "$ref": "#/$defs/evaluation" },
    "package": { "$ref": "#/$defs/package" }
  },
  "$defs": {
    "path": { "type": "string", "minLength": 1 },
    "globs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "seed", "artifact_dir"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "seed": { "type": "integer", "minimum": 0 },
        "artifact_dir": { "$ref": "#/$defs/path" }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "id", "revision", "loader", "trust_remote_code", "dtype", "max_sequence_length", "quantization"],
      "properties": {
        "provider": { "const": "huggingface" },
        "id": { "type": "string", "minLength": 3 },
        "revision": { "type": "string", "minLength": 1 },
        "loader": { "enum": ["qwen3_5_text", "auto_text_causal_lm"] },
        "trust_remote_code": { "const": false },
        "dtype": { "const": "bfloat16" },
        "max_sequence_length": { "type": "integer", "minimum": 256 },
        "quantization": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method", "quant_type", "double_quant", "compute_dtype"],
          "properties": {
            "method": { "const": "bitsandbytes-4bit" },
            "quant_type": { "const": "nf4" },
            "double_quant": { "const": true },
            "compute_dtype": { "const": "bfloat16" }
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "uri", "partition", "roles"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "kind": { "enum": ["repository", "sft_jsonl", "task_pack"] },
        "uri": { "type": "string", "minLength": 1 },
        "partition": { "enum": ["train", "evaluation"] },
        "roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["style", "history", "rl_seed", "demonstrations", "rl_tasks", "evaluation"] }
        },
        "revision": { "type": "string", "minLength": 1 },
        "include": { "$ref": "#/$defs/globs" },
        "exclude": { "$ref": "#/$defs/globs" },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "preset": { "type": "string", "minLength": 1 },
            "working_directory": { "$ref": "#/$defs/path" },
            "install": { "type": "string", "minLength": 1 },
            "build": { "type": "string", "minLength": 1 },
            "test": { "type": "string", "minLength": 1 },
            "browser_test": { "type": "string", "minLength": 1 }
          }
        },
        "license": {
          "type": "object",
          "additionalProperties": false,
          "required": ["spdx"],
          "properties": {
            "spdx": { "type": "string", "minLength": 1 },
            "attribution": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "qlora": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rank", "alpha", "dropout", "target_modules", "bias"],
      "properties": {
        "rank": { "type": "integer", "minimum": 1 },
        "alpha": { "type": "integer", "minimum": 1 },
        "dropout": { "type": "number", "minimum": 0, "maximum": 1 },
        "target_modules": { "const": "all-linear" },
        "bias": { "const": "none" }
      }
    },
    "sft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "dataset", "output_dir", "max_length", "per_device_train_batch_size", "gradient_accumulation_steps", "learning_rate", "num_train_epochs", "bf16", "tf32", "gradient_checkpointing", "completion_only_loss", "assistant_only_loss", "packing", "seed", "logging_steps", "save_steps"],
      "properties": {
        "enabled": { "const": true },
        "dataset": { "$ref": "#/$defs/path" },
        "eval_dataset": { "$ref": "#/$defs/path" },
        "output_dir": { "$ref": "#/$defs/path" },
        "max_length": { "type": "integer", "minimum": 256 },
        "per_device_train_batch_size": { "type": "integer", "minimum": 1 },
        "gradient_accumulation_steps": { "type": "integer", "minimum": 1 },
        "learning_rate": { "type": "number", "exclusiveMinimum": 0 },
        "num_train_epochs": { "type": "number", "exclusiveMinimum": 0 },
        "bf16": { "const": true },
        "tf32": { "type": "boolean" },
        "gradient_checkpointing": { "const": true },
        "completion_only_loss": { "const": true },
        "assistant_only_loss": { "const": true },
        "packing": { "const": false },
        "seed": { "type": "integer", "minimum": 0 },
        "logging_steps": { "type": "integer", "minimum": 1 },
        "save_steps": { "type": "integer", "minimum": 1 },
        "save_total_limit": { "type": "integer", "minimum": 1 }
      }
    },
    "grpo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "algorithm", "dataset", "sft_adapter", "output_dir", "max_steps", "per_device_train_batch_size", "gradient_accumulation_steps", "num_generations", "generation_batch_size", "max_completion_length", "max_tool_calling_iterations", "learning_rate", "beta", "loss_type", "bf16", "tf32", "gradient_checkpointing", "use_vllm", "temperature", "top_p", "top_k", "seed"],
      "properties": {
        "enabled": { "const": true },
        "algorithm": { "const": "grpo" },
        "dataset": { "$ref": "#/$defs/path" },
        "sft_adapter": { "$ref": "#/$defs/path" },
        "output_dir": { "$ref": "#/$defs/path" },
        "max_steps": { "type": "integer", "minimum": 1 },
        "per_device_train_batch_size": { "type": "integer", "minimum": 1 },
        "gradient_accumulation_steps": { "type": "integer", "minimum": 1 },
        "num_generations": { "type": "integer", "minimum": 2 },
        "generation_batch_size": { "type": "integer", "minimum": 2 },
        "max_completion_length": { "type": "integer", "minimum": 128 },
        "max_tool_calling_iterations": { "type": "integer", "minimum": 1 },
        "learning_rate": { "type": "number", "exclusiveMinimum": 0 },
        "beta": { "type": "number", "minimum": 0 },
        "loss_type": { "const": "dapo" },
        "bf16": { "const": true },
        "tf32": { "type": "boolean" },
        "gradient_checkpointing": { "const": true },
        "use_vllm": { "const": false },
        "temperature": { "type": "number", "exclusiveMinimum": 0 },
        "top_p": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "top_k": { "type": "integer", "minimum": 0 },
        "seed": { "type": "integer", "minimum": 0 },
        "logging_steps": { "type": "integer", "minimum": 1 },
        "save_steps": { "type": "integer", "minimum": 1 },
        "save_total_limit": { "type": "integer", "minimum": 1 }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["factory", "backend", "image", "network", "max_tool_output_chars", "episode_timeout_seconds"],
      "properties": {
        "factory": { "const": "autotrainer.environments.frontend:FrontendEnvironment" },
        "backend": { "enum": ["docker", "podman"] },
        "image": { "type": "string", "minLength": 1 },
        "network": { "const": "none" },
        "max_tool_output_chars": { "type": "integer", "minimum": 1 },
        "episode_timeout_seconds": { "type": "integer", "minimum": 1 }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidates", "primary_metric"],
      "properties": {
        "task_pack": { "$ref": "#/$defs/path" },
        "candidates": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "holdout_unit": { "const": "repository" },
        "primary_metric": { "const": "verified_task_success" },
        "metrics": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["verified_task_success", "build_rate", "task_pass_rate", "regression_rate", "accessibility", "responsive", "tokens_per_success", "wall_time_per_success"] }
        },
        "fable_a_b": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "blind_review"],
          "properties": {
            "enabled": { "type": "boolean" },
            "suite": { "$ref": "#/$defs/path" },
            "blind_review": { "const": true }
          }
        }
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "type": { "const": "lora_adapter" },
        "winner": { "enum": ["best", "sft", "grpo"] },
        "output_dir": { "$ref": "#/$defs/path" },
        "merge_base_weights": { "const": false },
        "include": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["adapter", "system_prompt", "tool_schema", "evaluation_report", "source_license_manifest", "resolved_recipe"] }
        }
      }
    }
  }
}
