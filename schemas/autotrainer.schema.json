{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autotrainer.dev/schemas/autotrainer.schema.json",
  "title": "AutoTrainer experiment configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project", "model", "sources", "qlora", "sft", "grpo", "environment", "evaluation", "package"],
  "properties": {
    "schema_version": { "const": 1 },
    "project": { "$ref": "#/$defs/project" },
    "model": { "$ref": "#/$defs/model" },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" }
    },
    "qlora": { "$ref": "#/$defs/qlora" },
    "sft": { "$ref": "#/$defs/sft" },
    "grpo": { "$ref": "#/$defs/grpo" },
    "environment": { "$ref": "#/$defs/environment" },
    "evaluation": { "$ref": "#/$defs/evaluation" },
    "package": { "$ref": "#/$defs/package" }
  },
  "$defs": {
    "path": { "type": "string", "minLength": 1 },
    "globs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "seed", "artifact_dir"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "seed": { "type": "integer", "minimum": 0 },
        "artifact_dir": { "$ref": "#/$defs/path" }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "id", "revision", "loader", "trust_remote_code", "dtype", "max_sequence_length", "quantization"],
      "properties": {
        "provider": { "const": "huggingface" },
        "id": { "type": "string", "minLength": 3 },
        "revision": { "type": "string", "minLength": 1 },
        "cache_dir": { "$ref": "#/$defs/path" },
        "loader": { "enum": ["qwen3_5_text", "auto_text_causal_lm"] },
        "trust_remote_code": { "const": false },
        "dtype": { "const": "bfloat16" },
        "max_sequence_length": { "type": "integer", "minimum": 256 },
        "quantization": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method", "quant_type", "double_quant", "compute_dtype"],
          "properties": {
            "method": { "const": "bitsandbytes-4bit" },
            "quant_type": { "const": "nf4" },
            "double_quant": { "const": true },
            "compute_dtype": { "const": "bfloat16" }
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "uri", "partition", "roles"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "kind": { "enum": ["repository", "sft_jsonl", "task_pack"] },
        "uri": { "type": "string", "minLength": 1 },
        "partition": { "enum": ["train", "evaluation"] },
        "roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["style", "history", "rl_seed", "demonstrations", "rl_tasks", "evaluation"] }
        },
        "revision": { "type": "string", "minLength": 1 },
        "include": { "$ref": "#/$defs/globs" },
        "exclude": { "$ref": "#/$defs/globs" },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "preset": { "type": "string", "minLength": 1 },
            "working_directory": { "$ref": "#/$defs/path" },
            "install": { "type": "string", "minLength": 1 },
            "build": { "type": "string", "minLength": 1 },
            "test": { "type": "string", "minLength": 1 },
            "browser_test": { "type": "string", "minLength": 1 }
          }
        },
        "license": {
          "type": "object",
          "additionalProperties": false,
          "required": ["spdx"],
          "properties": {
            "spdx": { "type": "string", "minLength": 1 },
            "attribution": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "qlora": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rank", "alpha", "dropout", "target_modules", "bias"],
      "properties": {
        "rank": { "type": "integer", "minimum": 1 },
        "alpha": { "type": "integer", "minimum": 1 },
        "dropout": { "type": "number", "minimum": 0, "maximum": 1 },
        "target_modules": { "const": "all-linear" },
        "bias": { "const": "none" }
      }
    },
    "sft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "dataset": { "$ref": "#/$defs/path" },
        "eval_dataset": { "$ref": "#/$defs/path" },
        "output_dir": { "$ref": "#/$defs/path" },
        "max_length": { "type": "integer", "minimum": 256 },
        "per_device_train_batch_size": { "type": "integer", "minimum": 1 },
        "gradient_accumulation_steps": { "type": "integer", "minimum": 1 },
        "learning_rate": { "type": "number", "exclusiveMinimum": 0 },
        "num_train_epochs": { "type": "number", "exclusiveMinimum": 0 },
        "bf16": { "const": true },
        "tf32": { "type": "boolean" },
        "gradient_checkpointing": { "const": true },
        "completion_only_loss": { "const": true },
        "assistant_only_loss": { "const": true },
        "packing": { "const": false },
        "seed": { "type": "integer", "minimum": 0 },
        "logging_steps": { "type": "integer", "minimum": 1 },
        "save_steps": { "type": "integer", "minimum": 1 },
        "save_total_limit": { "type": "integer", "minimum": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "enabled": { "const": true } }, "required": ["enabled"] },
          "then": {
            "required": ["dataset", "output_dir", "max_length", "per_device_train_batch_size", "gradient_accumulation_steps", "learning_rate", "num_train_epochs", "bf16", "tf32", "gradient_checkpointing", "completion_only_loss", "assistant_only_loss", "packing", "seed", "logging_steps", "save_steps"]
          }
        }
      ]
    },
    "grpo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "algorithm": { "const": "grpo" },
        "dataset": { "$ref": "#/$defs/path" },
        "eval_dataset": { "$ref": "#/$defs/path" },
        "start_from": { "$ref": "#/$defs/path" },
        "sft_adapter": { "$ref": "#/$defs/path" },
        "output_dir": { "$ref": "#/$defs/path" },
        "max_steps": { "type": "integer", "minimum": 1 },
        "per_device_train_batch_size": { "type": "integer", "minimum": 1 },
        "gradient_accumulation_steps": { "type": "integer", "minimum": 1 },
        "num_generations": { "type": "integer", "minimum": 2 },
        "generation_batch_size": { "type": "integer", "minimum": 2 },
        "max_completion_length": { "type": "integer", "minimum": 128 },
        "max_tool_calling_iterations": { "type": "integer", "minimum": 1 },
        "learning_rate": { "type": "number", "exclusiveMinimum": 0 },
        "beta": { "type": "number", "minimum": 0 },
        "loss_type": { "const": "dapo" },
        "bf16": { "const": true },
        "tf32": { "type": "boolean" },
        "gradient_checkpointing": { "const": true },
        "use_vllm": { "const": false },
        "temperature": { "type": "number", "exclusiveMinimum": 0 },
        "top_p": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "top_k": { "type": "integer", "minimum": 0 },
        "seed": { "type": "integer", "minimum": 0 },
        "logging_steps": { "type": "integer", "minimum": 1 },
        "save_steps": { "type": "integer", "minimum": 1 },
        "save_total_limit": { "type": "integer", "minimum": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "enabled": { "const": true } }, "required": ["enabled"] },
          "then": {
            "required": ["algorithm", "dataset", "output_dir", "max_steps", "per_device_train_batch_size", "gradient_accumulation_steps", "num_generations", "generation_batch_size", "max_completion_length", "max_tool_calling_iterations", "learning_rate", "beta", "loss_type", "bf16", "tf32", "gradient_checkpointing", "use_vllm", "temperature", "top_p", "top_k", "seed"],
            "anyOf": [
              { "required": ["start_from"] },
              { "required": ["sft_adapter"] }
            ]
          }
        }
      ]
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["factory", "backend", "image", "network", "max_tool_output_chars", "episode_timeout_seconds"],
      "properties": {
        "factory": { "const": "autotrainer.environments.frontend:FrontendEnvironment" },
        "backend": { "enum": ["docker", "podman"] },
        "image": { "type": "string", "minLength": 1 },
        "network": { "const": "none" },
        "max_tool_output_chars": { "type": "integer", "minimum": 1 },
        "episode_timeout_seconds": { "type": "integer", "minimum": 1 }
      }
    },
    "evaluation_external_model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "id", "revision", "loader", "trust_remote_code", "dtype", "max_sequence_length", "quantization"],
      "properties": {
        "provider": { "const": "huggingface" },
        "id": { "type": "string", "minLength": 3 },
        "revision": { "type": "string", "pattern": "^[0-9a-fA-F]{40,64}$" },
        "loader": { "enum": ["qwen3_5_text", "auto_text_causal_lm"] },
        "trust_remote_code": { "const": false },
        "dtype": { "const": "bfloat16" },
        "max_sequence_length": { "type": "integer", "minimum": 256 },
        "quantization": { "const": "project" }
      }
    },
    "evaluation_adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "stage"],
      "properties": {
        "path": { "$ref": "#/$defs/path" },
        "stage": { "enum": ["sft", "grpo"] },
        "sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" }
      }
    },
    "evaluation_arm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "role", "parameter_class", "model"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "role": { "enum": ["reference", "control", "candidate"] },
        "parameter_class": { "const": "9b" },
        "model": {
          "oneOf": [
            { "const": "project" },
            { "$ref": "#/$defs/evaluation_external_model" }
          ]
        },
        "adapter": { "$ref": "#/$defs/evaluation_adapter" }
      },
      "allOf": [
        {
          "if": { "properties": { "role": { "const": "reference" } }, "required": ["role"] },
          "then": {
            "properties": { "model": { "$ref": "#/$defs/evaluation_external_model" } },
            "not": { "required": ["adapter"] }
          }
        },
        {
          "if": { "properties": { "role": { "const": "control" } }, "required": ["role"] },
          "then": {
            "properties": { "model": { "const": "project" } },
            "not": { "required": ["adapter"] }
          }
        },
        {
          "if": { "properties": { "role": { "const": "candidate" } }, "required": ["role"] },
          "then": {
            "required": ["adapter"],
            "properties": { "model": { "const": "project" } }
          }
        }
      ]
    },
    "evaluation_command_runner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "producer", "version", "orchestration_sha256", "argv"],
      "properties": {
        "type": { "const": "command" },
        "producer": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "orchestration_sha256": { "type": "string", "pattern": "^sha256:[0-9a-fA-F]{64}$" },
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "allOf": [
            { "contains": { "type": "string", "pattern": "\\{request\\}" } },
            { "contains": { "type": "string", "pattern": "\\{result\\}" } }
          ]
        }
      }
    },
    "evaluation_builtin_runner": {
      "$comment": "Identity is derived from installed AutoTrainer code when the plan is frozen.",
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "builtin" }
      }
    },
    "evaluation_external_runner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "producer", "version", "orchestration_sha256", "result_schema"],
      "properties": {
        "type": { "const": "external" },
        "producer": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "orchestration_sha256": { "type": "string", "pattern": "^sha256:[0-9a-fA-F]{64}$" },
        "result_schema": { "type": "string", "minLength": 1 }
      }
    },
    "evaluation_model_suite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "arms", "runner"],
      "properties": {
        "kind": { "const": "model_benchmark" },
        "arms": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "runner": {
          "oneOf": [
            { "$ref": "#/$defs/evaluation_builtin_runner" },
            { "$ref": "#/$defs/evaluation_command_runner" }
          ]
        }
      }
    },
    "evaluation_fable_suite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "arms", "runner", "review"],
      "properties": {
        "kind": { "const": "fable_ab" },
        "arms": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "runner": { "$ref": "#/$defs/evaluation_external_runner" },
        "review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "blind", "reviewers_per_pair"],
          "properties": {
            "type": { "const": "manual" },
            "blind": { "const": true },
            "reviewers_per_pair": { "type": "integer", "minimum": 1 },
            "viewports": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string", "pattern": "^[1-9][0-9]*x[1-9][0-9]*$" }
            }
          }
        }
      }
    },
    "evaluation_fairness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paired_by", "same_task_snapshot", "same_instruction", "same_tools_and_limits", "same_verifier", "same_runner_within_suite", "same_sampling", "require_seed_control", "immutable_models_and_adapter", "failures_score_zero", "allow_unplanned_reruns"],
      "oneOf": [
        {
          "required": ["pair_position_policy", "execution_order_policy", "per_trial_arm_randomization"],
          "not": { "required": ["randomize_arm_order"] }
        },
        {
          "$comment": "Backward-compatible input; frozen plans convert this old claim to the truthful grouped V1 policy.",
          "required": ["randomize_arm_order"],
          "not": {
            "anyOf": [
              { "required": ["pair_position_policy"] },
              { "required": ["execution_order_policy"] },
              { "required": ["per_trial_arm_randomization"] }
            ]
          }
        }
      ],
      "properties": {
        "paired_by": {
          "type": "array",
          "prefixItems": [
            { "const": "task_id" },
            { "const": "repetition" },
            { "const": "seed" }
          ],
          "items": false,
          "minItems": 3,
          "maxItems": 3
        },
        "same_task_snapshot": { "const": true },
        "same_instruction": { "const": true },
        "same_tools_and_limits": { "const": true },
        "same_verifier": { "const": true },
        "same_runner_within_suite": { "const": true },
        "same_sampling": { "const": true },
        "require_seed_control": { "const": true },
        "immutable_models_and_adapter": { "const": true },
        "randomize_arm_order": { "const": true },
        "pair_position_policy": { "const": "deterministic_counterbalance" },
        "execution_order_policy": { "const": "frozen_per_suite" },
        "per_trial_arm_randomization": { "const": false },
        "failures_score_zero": { "const": true },
        "allow_unplanned_reruns": { "const": false }
      }
    },
    "evaluation_decisions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confidence", "model_benchmark", "fable_ab"],
      "properties": {
        "confidence": { "type": "number", "exclusiveMinimum": 0.5, "exclusiveMaximum": 1 },
        "model_benchmark": {
          "type": "object",
          "additionalProperties": false,
          "required": ["candidate", "control", "metric", "minimum_delta", "minimum_tasks"],
          "properties": {
            "candidate": { "type": "string", "minLength": 1 },
            "control": { "type": "string", "minLength": 1 },
            "metric": { "const": "verified_task_success" },
            "minimum_delta": { "type": "number", "minimum": -1, "maximum": 1 },
            "minimum_tasks": { "type": "integer", "minimum": 5 }
          }
        },
        "fable_ab": {
          "type": "object",
          "additionalProperties": false,
          "required": ["candidate", "control", "metric", "minimum_rate", "minimum_tasks"],
          "properties": {
            "candidate": { "type": "string", "minLength": 1 },
            "control": { "type": "string", "minLength": 1 },
            "metric": { "const": "blind_preference_rate" },
            "minimum_rate": { "type": "number", "minimum": 0, "maximum": 1 },
            "minimum_tasks": { "type": "integer", "minimum": 5 }
          }
        }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dataset", "task_pack", "task_split", "repetitions", "seeds", "holdout_unit", "primary_metric", "candidates", "arms", "suites", "fairness", "decisions"],
      "properties": {
        "dataset": { "$ref": "#/$defs/path" },
        "task_pack": { "$ref": "#/$defs/path" },
        "task_split": { "const": "evaluation" },
        "repetitions": { "type": "integer", "minimum": 1 },
        "seeds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 0 }
        },
        "holdout_unit": { "const": "repository" },
        "primary_metric": { "const": "verified_task_success" },
        "candidates": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "arms": {
          "type": "object",
          "minProperties": 3,
          "maxProperties": 3,
          "propertyNames": { "pattern": "^[a-z0-9][a-z0-9_-]*$" },
          "additionalProperties": { "$ref": "#/$defs/evaluation_arm" }
        },
        "suites": {
          "type": "object",
          "additionalProperties": false,
          "required": ["model_benchmark", "fable_ab"],
          "properties": {
            "model_benchmark": { "$ref": "#/$defs/evaluation_model_suite" },
            "fable_ab": { "$ref": "#/$defs/evaluation_fable_suite" }
          }
        },
        "fairness": { "$ref": "#/$defs/evaluation_fairness" },
        "decisions": { "$ref": "#/$defs/evaluation_decisions" }
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "type": { "const": "lora_adapter" },
        "winner": { "enum": ["best", "sft", "grpo"] },
        "output_dir": { "$ref": "#/$defs/path" },
        "merge_base_weights": { "const": false },
        "include": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["adapter", "system_prompt", "tool_schema", "evaluation_report", "source_license_manifest", "resolved_recipe"] }
        }
      }
    }
  }
}
