{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autotrainer.local/schemas/frontend-task.schema.json",
  "title": "AutoTrainer frontend RL task",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "task", "runtime", "tools", "rewards", "limits"],
  "properties": {
    "version": { "const": "0.1" },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "instruction", "startingSnapshot", "split"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "instruction": { "type": "string", "minLength": 20 },
        "startingSnapshot": { "type": "string", "minLength": 1 },
        "split": { "enum": ["train", "evaluation"] }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stack", "install", "build", "tests", "browserTests"],
      "properties": {
        "stack": { "const": "react-vite-tailwind" },
        "install": { "type": "string" },
        "build": { "type": "string" },
        "tests": { "type": "string" },
        "browserTests": { "type": "string" }
      }
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["read_file", "search_code", "apply_patch", "run_command", "inspect_browser"] }
    },
    "rewards": {
      "type": "object",
      "additionalProperties": false,
      "required": ["buildGate", "regressionGate", "regressionSafety", "taskTests", "responsiveRules", "designRules", "patchQuality"],
      "properties": {
        "buildGate": { "const": true },
        "regressionGate": { "const": true },
        "regressionSafety": { "type": "number", "minimum": 0, "maximum": 1 },
        "taskTests": { "type": "number", "minimum": 0, "maximum": 1 },
        "responsiveRules": { "type": "number", "minimum": 0, "maximum": 1 },
        "designRules": { "type": "number", "minimum": 0, "maximum": 1 },
        "patchQuality": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["toolCalls", "tokenBudget", "commandTimeoutSeconds", "networkAccess"],
      "properties": {
        "toolCalls": { "type": "integer", "minimum": 1 },
        "tokenBudget": { "type": "integer", "minimum": 256 },
        "commandTimeoutSeconds": { "type": "integer", "minimum": 1 },
        "networkAccess": { "const": false }
      }
    }
  }
}
